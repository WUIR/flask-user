# ── Flask ──────────────────────────────────────────────────────
FLASK_APP=manage.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-another-random-secret

# ── Database ───────────────────────────────────────────────────
# Development: SQLite
DATABASE_URL=sqlite:///dev.db
# Production (PostgreSQL in Docker):
# DATABASE_URL=postgresql://flask_user:your_password@db:5432/flask_user

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin seed ─────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123456

# ── Production (used by docker-compose) ────────────────────────
POSTGRES_USER=flask_user
POSTGRES_PASSWORD=change_me_too
POSTGRES_DB=flask_user
